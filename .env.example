# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=waf_db

# ONNX model paths (inside container, mounted from ml/exported_models/)
L2A_MODEL_PATH=/models/layer2a_best.onnx
L2B_MODEL_PATH=/models/layer2b_best.onnx

# Which model won each layer - for dashboard display only
L2A_MODEL_NAME=isolation_forest
L2B_MODEL_NAME=gru

# Threat score thresholds
SCORE_ALLOW_THRESHOLD=30
SCORE_BLOCK_THRESHOLD=70

# Rate limiting
RATE_LIMIT_RPM=100

# App
APP_PORT=8000
DEBUG=false
